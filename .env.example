# Mock mode keeps all MiniMax calls local; no creds needed.
NEXT_PUBLIC_MOCK=1

# Database (Prisma). Defaults to a local SQLite file in ./prisma/dev.db.
# Production target is Postgres; swap the provider + this URL together.
DATABASE_URL=file:./prisma/dev.db

# Real-mode credentials (v1; do not commit).
# MINIMAX_LLM_BASE_URL=
# MINIMAX_LLM_API_KEY=
# MINIMAX_ASR_BASE_URL=
# MINIMAX_ASR_API_KEY=
# MINIMAX_TTS_BASE_URL=
# MINIMAX_TTS_API_KEY=
# MINIMAX_PRONUNCIATION_BASE_URL=
# MINIMAX_PRONUNCIATION_API_KEY=