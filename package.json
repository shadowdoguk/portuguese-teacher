{
  "name": "portuguese-teacher",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "progress:check": "node scripts/progress-check.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "seed:a0": "tsx prisma/seed.ts --dialect pt-PT --level A0",
    "assets:tts": "tsx scripts/build-tts-assets.ts",
    "assets:check": "tsx scripts/check-tts-assets.ts",
    "anchors:suggest": "tsx scripts/anchors-suggest.ts",
    "harness:live": "node scripts/run-ab-harness-live.mjs",
    "harness:mock": "vitest run -- ab-harness",
    "load:test": "node scripts/load-test-srs-events.mjs",
    "test:a11y": "vitest run src/test/axe-a11y.test.tsx",
    "perf:budget": "tsx scripts/perf-budget.ts",
    "perf:budget:update": "tsx scripts/perf-budget.ts --update-baseline",
    "perf:budget:test": "vitest run scripts/perf-budget.test.ts",
    "perf:analyze": "ANALYZE=true next build",
    "perf:lighthouse": "lhci autorun",
    "asr:regress": "tsx scripts/asr-regress.ts",
    "asr:regress:update": "tsx scripts/asr-regress.ts --update-baseline",
    "asr:regress:test": "vitest run src/test/asr-wer.test.ts src/test/asr-simulator.test.ts"
  },
  "dependencies": {
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@lhci/cli": "0.15.1",
    "@next/bundle-analyzer": "14.2.35",
    "@prisma/client": "5.22.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@types/node": "20.17.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "autoprefixer": "10.4.20",
    "axe-core": "^4.12.1",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.18",
    "jsdom": "25.0.1",
    "postcss": "8.4.49",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.14",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4",
    "webpack-bundle-analyzer": "4.10.1"
  }
}